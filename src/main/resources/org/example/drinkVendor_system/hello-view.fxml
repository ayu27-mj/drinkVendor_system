<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drinkVendor_system.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <TextField />
   <Label fx:id="display" />
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
      <children>
          <Button fx:id="one" onAction="#onButtonClick" text="1" />
         <Button fx:id="plus" onAction="#onButtonClick" text="+" />
         <Button fx:id="two" onAction="#onButtonClick" text="2" />
         <Button fx:id="equal" onAction="#onButtonClick" text="=" />
      </children>
   </HBox>
</VBox>
